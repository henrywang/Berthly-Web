---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import mainWindow from "../assets/screenshots/main-window.png";
import commandPalette from "../assets/screenshots/command-palette.png";
import detailPane from "../assets/screenshots/detail-pane.png";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });

const features = [
  { title: "Images", body: "List, pull from a registry, build from a Dockerfile, and inspect layers and metadata." },
  { title: "Containers", body: "Create and run containers, view details, and stream logs live as they happen." },
  { title: "Machines", body: "Create and manage VMs, set the kernel, and inspect resources." },
  { title: "Networks & volumes", body: "Create, list, and remove them without touching a terminal." },
  { title: "Registries", body: "Sign in to private registries; credentials live in your macOS Keychain." },
  { title: "Integrated terminal", body: "A real terminal attached to your containers, built on SwiftTerm." },
  { title: "Command palette", body: "Jump to any action with a keystroke — ⌘K and go." },
  { title: "Menu-bar presence", body: "Quick status and controls without leaving what you're doing." },
  { title: "Rebuild in one click", body: "Every build's context and flags are remembered, so re-running one never means re-entering anything." },
  { title: "Builds keep going", body: "Close the build sheet and keep working — the toolbar indicator tracks progress and surfaces failures." },
  { title: "Disk hygiene at a glance", body: "Reclaimable-space badges on Images and Volumes, with confirmed one-click pruning." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Berthly",
  operatingSystem: "macOS 26",
  applicationCategory: "DeveloperApplication",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  url: "https://berthly.net",
  downloadUrl: "https://github.com/henrywang/Berthly/releases/latest",
  softwareVersion: "1.0.1",
  description:
    "A native macOS GUI for Apple's container tool — build images, run containers and machines, manage networks and volumes, and tail logs.",
};
---

<Base
  title="Berthly — a native macOS GUI for Apple's container"
  description="Build images, run containers and machines, manage networks and volumes, and tail logs from a real GUI instead of the command line. Free & open source."
  jsonLd={jsonLd}
>
  <section class="hero">
    <div class="container">
      <a class="badge" href="/blog/berthly-1-0-1/"
        ><span class="dot"></span>Berthly v1.0.1 is out · Free &amp; open source</a
      >
      <h1>Apple's container,<br />finally with a <span class="accent">face.</span></h1>
      <p class="sub">
        Berthly is a native macOS app for Apple's <code>container</code> tool — build images, run
        containers and machines, manage networks and volumes, and tail logs from a real GUI instead
        of the command line.
      </p>
      <div class="ctas">
        <a class="btn lg btn-primary" href="https://github.com/henrywang/Berthly/releases/latest">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 1v8.6L4.7 6.3 3.3 7.7 8 12.4l4.7-4.7-1.4-1.4L8 9.6V1zM2 13h12v2H2z"></path></svg>
          Download for macOS
        </a>
        <a class="btn lg btn-secondary" href="https://github.com/henrywang/Berthly">View on GitHub</a>
      </div>
      <p class="fine">Apple Silicon · macOS 26 or later · works with Apple's <b>container</b> daemon</p>
      <figure class="hero-shot">
        <Image
          src={mainWindow}
          alt="Berthly's main window: the Compute list with a container's live CPU, memory, and network charts"
          widths={[760, 1140, 1640, 2624]}
          sizes="(max-width: 1080px) 100vw, 1032px"
          loading="eager"
        />
      </figure>
    </div>
  </section>

  <section class="strip">
    <div class="container">
      <p>
        <a href="https://github.com/apple/container">Apple's <code>container</code></a> runs Linux
        containers in lightweight VMs on Apple Silicon — fast, native, and built by Apple. It ships
        as a command-line tool. <b>Berthly is the GUI it's missing</b>: the Docker Desktop-style
        experience, driving the same daemon underneath.
      </p>
    </div>
  </section>

  <section class="tour">
    <div class="container">
      <div class="row">
        <div class="copy">
          <div class="caption">Command palette</div>
          <h3>⌘K, and you're there</h3>
          <p>
            Every action — run a container, start a machine, pull an image — is a keystroke away.
            Berthly is keyboard-first throughout: <kbd>⌘K</kbd> opens the palette,
            <kbd>⌘1–6</kbd> switch sections, <kbd>⌘⌥1–3</kbd> jump between a container's
            Overview, Logs, and Terminal.
          </p>
          <p class="more">
            <a href="/docs/shortcuts/">See all keyboard shortcuts →</a>
          </p>
        </div>
        <figure>
          <Image
            src={commandPalette}
            alt="The command palette (⌘K) matching lifecycle actions for a container"
            widths={[640, 960, 1440]}
            sizes="(max-width: 860px) 100vw, 620px"
          />
        </figure>
      </div>
      <div class="row flip">
        <div class="copy">
          <div class="caption">Live monitoring</div>
          <h3>Watch without watching</h3>
          <p>
            Live CPU, memory, and network charts for every container — something the CLI simply
            can't show you. Pin your favorites to the menu bar and get a notification when one
            changes state while you're elsewhere.
          </p>
          <p class="more">Inspect status, ports, mounts, networks, and environment at a glance.</p>
        </div>
        <figure class="framed">
          <Image
            src={detailPane}
            alt="A container's detail view: live CPU, memory, and network charts above the inspect table"
            widths={[640, 960, 1290]}
            sizes="(max-width: 860px) 100vw, 560px"
          />
        </figure>
      </div>
    </div>
  </section>

  <section class="features" id="features">
    <div class="container">
      <div class="caption center">Features</div>
      <h2>Everything the CLI does, without the CLI</h2>
      <p class="lede">
        Berthly drives the same <code>container</code> daemon you already use — it just gives you
        eyes and hands.
      </p>
      <div class="grid">
        {
          features.map((f) => (
            <div class="card">
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="start" id="get-started">
    <div class="container center">
      <div class="caption">Get started</div>
      <h2>Running in 30 seconds</h2>
      <div class="steps">
        <div class="step">
          <span class="num">1</span>
          <h3>Download the DMG</h3>
          <p>
            Grab <code>Berthly-1.0.1.dmg</code> from the
            <a href="https://github.com/henrywang/Berthly/releases/latest">latest release</a>.
            It's Developer ID–signed and notarized by Apple — no warnings, no workarounds.
          </p>
        </div>
        <div class="step">
          <span class="num">2</span>
          <h3>Drag to Applications</h3>
          <p>
            Open the DMG and drag <b>Berthly.app</b> into Applications. Updates arrive in-app
            from then on — Berthly&nbsp;→&nbsp;Check for Updates.
          </p>
        </div>
        <div class="step">
          <span class="num">3</span>
          <h3>Launch — that's it</h3>
          <p>
            No daemon yet? Berthly installs Apple's signed <code>container</code> toolchain and
            starts and monitors the daemon for you.
          </p>
        </div>
      </div>
      <p class="note"><a href="/docs/getting-started/">Read the full getting-started guide →</a></p>
    </div>
  </section>

  <section class="privacy">
    <div class="container center">
      <div class="caption rope">Privacy</div>
      <h2>Everything stays on your Mac</h2>
      <p class="lede">
        Berthly is a local tool, and it behaves like one. It talks only to the local
        <code>container</code> daemon over XPC — no telemetry, no analytics, no calls home.
      </p>
      <div class="points">
        <div class="pt">
          <h3>No telemetry</h3>
          <p>No analytics, no crash reporting, no calls home. The only network traffic is your own image pulls and pushes.</p>
        </div>
        <div class="pt">
          <h3>Keychain-only credentials</h3>
          <p>Registry sign-ins live in the same macOS Keychain items the CLI uses. Nowhere else, ever.</p>
        </div>
        <div class="pt">
          <h3>Open code</h3>
          <p>Apache-2.0 on GitHub. Not sandboxed by necessity — so audit exactly what it does.</p>
        </div>
      </div>
      <p class="note">
        Found a vulnerability?
        <a href="https://github.com/henrywang/Berthly/blob/main/SECURITY.md">Report it privately →</a>
      </p>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="latest">
        <div class="container">
          <div class="caption">From the blog</div>
          <div class="head">
            <h2>Latest posts</h2>
            <a class="all" href="/blog/">All posts →</a>
          </div>
          <div class="posts">
            {posts.map((post) => (
              <a class="post" href={`/blog/${post.id}/`}>
                <div class="meta">
                  <span class:list={["tag", `tag-${post.data.tags[0]}`]}>{post.data.tags[0]}</span>
                  <span>{fmt(post.data.date)}</span>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</Base>

<style>
  section { padding: 72px 0; }
  h2 { font-size: 36px; font-weight: 750; letter-spacing: -0.02em; }
  .center { text-align: center; }
  code { font-size: 0.92em; color: var(--accent); }

  .hero {
    background: linear-gradient(180deg, var(--bg) 0%, var(--wash) 100%);
    text-align: center;
    padding-bottom: 0;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    background: var(--panel);
    border: 1px solid var(--water);
    border-radius: 999px;
    padding: 5px 14px;
    margin-bottom: 22px;
    text-decoration: none;
  }
  .badge:hover { border-color: var(--accent); }
  :global([data-theme="dark"]) .badge { border-color: #2e4368; }
  .badge .dot { width: 7px; height: 7px; border-radius: 50%; background: #2ecc71; }
  h1 {
    font-size: clamp(38px, 7vw, 56px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }
  h1 .accent { color: var(--accent); }
  .sub {
    font-size: 19px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 56ch;
    margin: 20px auto 0;
  }
  .sub code {
    font-size: 16.5px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1px 6px;
  }
  .ctas { display: flex; justify-content: center; gap: 14px; margin-top: 30px; flex-wrap: wrap; }
  .fine { font-size: 13.5px; color: var(--muted); margin-top: 14px; }

  .hero-shot {
    max-width: 1032px;
    margin: 40px auto 0;
  }
  .hero-shot img {
    width: 100%;
    height: auto;
    display: block;
  }

  .strip { padding: 48px 0; border-bottom: 1px solid var(--border-soft); }
  .strip p {
    font-size: 18px;
    line-height: 1.7;
    color: var(--body);
    max-width: 64ch;
    margin: 0 auto;
    text-align: center;
  }

  .tour { padding-bottom: 24px; }
  .tour .row {
    display: grid;
    grid-template-columns: 5fr 7fr;
    gap: 56px;
    align-items: center;
  }
  .tour .row + .row { margin-top: 72px; }
  .tour .row.flip .copy { order: 2; }
  .tour .row.flip figure { order: 1; }
  .tour h3 {
    font-size: 27px;
    font-weight: 750;
    letter-spacing: -0.018em;
    margin: 10px 0 12px;
  }
  .tour .copy p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--body);
  }
  .tour .copy .more { margin-top: 12px; font-size: 14.5px; color: var(--muted); }
  .tour .copy .more a { font-weight: 600; text-decoration: none; }
  .tour kbd {
    font-size: 13.5px;
    background: var(--wash);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1px 6px;
  }
  .tour figure { margin: 0; }
  .tour figure img { width: 100%; height: auto; display: block; }
  .tour figure.framed img {
    border-radius: 14px;
    border: 1px solid var(--border);
    box-shadow: 0 20px 48px -20px rgba(11, 21, 38, 0.45);
  }
  @media (max-width: 860px) {
    .tour .row { grid-template-columns: 1fr; gap: 28px; }
    .tour .row.flip .copy { order: 1; }
    .tour .row.flip figure { order: 2; }
  }

  .start { background: var(--wash); }
  .start h2 { margin: 10px 0 32px; }
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    text-align: left;
  }
  .step {
    background: var(--panel);
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    padding: 22px 20px;
  }
  .step .num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(180deg, var(--bright), var(--brand));
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .step h3 { font-size: 16.5px; font-weight: 700; margin-bottom: 8px; }
  .step p { font-size: 14px; line-height: 1.6; color: var(--muted); }
  .start .note { margin-top: 28px; font-size: 14.5px; }
  .start .note a { font-weight: 600; text-decoration: none; }
  @media (max-width: 760px) { .steps { grid-template-columns: 1fr; } }

  .features h2 { text-align: center; margin: 10px 0 8px; }
  .features .lede {
    font-size: 17px;
    color: var(--muted);
    text-align: center;
    max-width: 52ch;
    margin: 0 auto 40px;
    line-height: 1.6;
  }
  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .card {
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    padding: 20px 18px;
    background: var(--panel);
    transition: box-shadow 0.15s, border-color 0.15s;
  }
  .card:hover { box-shadow: 0 8px 24px -8px rgba(42, 111, 219, 0.18); border-color: var(--water); }
  :global([data-theme="dark"]) .card:hover { border-color: #2e4368; }
  .card h3 { font-size: 15.5px; font-weight: 650; margin-bottom: 6px; }
  .card p { font-size: 13.5px; line-height: 1.55; color: var(--muted); }
  @media (max-width: 900px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .grid { grid-template-columns: 1fr; } }

  .privacy { background: var(--navy); color: #e8f0fb; }
  .privacy .rope { color: var(--rope); }
  .privacy h2 { margin: 10px 0 12px; }
  .privacy .lede { font-size: 17px; line-height: 1.65; color: #9db2ce; max-width: 54ch; margin: 0 auto 36px; }
  .privacy code { color: var(--rope); }
  .points { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; text-align: left; }
  .pt { background: var(--navy-2); border: 1px solid var(--navy-border); border-radius: 14px; padding: 18px; }
  .pt h3 { font-size: 15px; font-weight: 650; margin-bottom: 6px; }
  .pt p { font-size: 13.5px; line-height: 1.55; color: #9db2ce; }
  .note { margin-top: 26px; font-size: 13.5px; color: #7d92b3; }
  .note a { color: var(--rope); }
  @media (max-width: 760px) { .points { grid-template-columns: 1fr; } }

  .latest .head { display: flex; align-items: baseline; justify-content: space-between; margin: 10px 0 20px; }
  .latest .all { font-size: 14.5px; font-weight: 600; text-decoration: none; }
  .posts { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .post {
    display: block;
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    padding: 20px 18px;
    text-decoration: none;
    color: inherit;
    background: var(--panel);
  }
  .post:hover { border-color: var(--water); }
  .post .meta { display: flex; align-items: center; gap: 10px; font-size: 12.5px; color: var(--muted); margin-bottom: 10px; }
  .post h3 { font-size: 16.5px; font-weight: 700; letter-spacing: -0.01em; margin-bottom: 6px; }
  .post:hover h3 { color: var(--accent); }
  .post p { font-size: 13.5px; line-height: 1.55; color: var(--muted); }
  @media (max-width: 760px) { .posts { grid-template-columns: 1fr; } }
</style>
