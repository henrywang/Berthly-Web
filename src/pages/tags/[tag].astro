---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostList from "../../components/PostList.astro";

export async function getStaticPaths() {
  const tags = ["design", "devlog", "release", "news"];
  return tags.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const posts = (await getCollection("blog", (post) => post.data.tags.includes(tag as never)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base
  title={`${tag} — Berthly blog`}
  description={`Berthly blog posts tagged “${tag}”.`}
>
  <div class="container wrap">
    <p class="crumb"><a href="/blog/">← All posts</a></p>
    <h1>Tagged: {tag}</h1>
    {posts.length === 0 && <p class="empty">Nothing here yet — check back soon.</p>}
    <PostList posts={posts} />
  </div>
</Base>

<style>
  .wrap { max-width: 760px; padding-block: 56px; }
  .crumb { font-size: 14px; margin-bottom: 10px; }
  .crumb a { text-decoration: none; font-weight: 600; }
  h1 { font-size: 32px; font-weight: 750; letter-spacing: -0.02em; text-transform: capitalize; }
  .empty { margin-top: 16px; color: var(--muted); }
</style>
