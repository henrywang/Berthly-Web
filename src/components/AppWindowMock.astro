---
// CSS mock of the Berthly main window — placeholder until real screenshots land.
const sidebar = [
  { label: "Images", on: false },
  { label: "Containers", on: true },
  { label: "Machines", on: false },
  { label: "Networks", on: false },
  { label: "Volumes", on: false },
  { label: "Registries", on: false },
];
const rows = [
  { name: "web", image: "nginx:alpine", running: true, usage: "0.4% · 18 MB" },
  { name: "api", image: "swift:6.1-slim", running: true, usage: "2.1% · 96 MB" },
  { name: "db", image: "postgres:17", running: true, usage: "1.2% · 210 MB" },
  { name: "worker", image: "redis:7", running: false, usage: "—" },
];
---

<div class="shot" role="img" aria-label="Berthly main window showing running containers">
  <div class="titlebar">
    <span class="lights"><i class="r"></i><i class="y"></i><i class="g"></i></span>
    <span class="title">Berthly</span>
    <span class="spacer"></span>
  </div>
  <div class="win">
    <div class="sidebar">
      {sidebar.map((item) => <div class:list={["side-item", { on: item.on }]}>{item.label}</div>)}
    </div>
    <div class="main">
      <div class="toolbar">
        <span class="search">Search containers…</span>
        <span class="grow"></span>
        <span class="act">＋ New container</span>
      </div>
      <table>
        <thead>
          <tr><th>Name</th><th>Image</th><th>Status</th><th>CPU / Mem</th></tr>
        </thead>
        <tbody>
          {
            rows.map((row) => (
              <tr>
                <td>{row.name}</td>
                <td class="mono">{row.image}</td>
                <td>
                  <span class:list={["pill", row.running ? "run" : "stop"]}>
                    <i />
                    {row.running ? "Running" : "Stopped"}
                  </span>
                </td>
                <td class="mono">{row.usage}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
      <div class="logs">
        <div class="logline"><b>web</b> 172.20.0.2 - - "GET /health HTTP/1.1" 200 —</div>
        <div class="logline"><b>api</b> [info] listening on 0.0.0.0:8080</div>
        <div class="logline"><b>db&nbsp;</b> LOG: database system is ready to accept connections</div>
      </div>
    </div>
  </div>
</div>

<style>
  /* The mock window keeps its own fixed light-macOS palette in both themes. */
  .shot {
    margin: 52px auto 0;
    max-width: 960px;
    text-align: left;
    border-radius: 14px 14px 0 0;
    overflow: hidden;
    box-shadow: 0 30px 80px -20px rgba(14, 27, 44, 0.35), 0 0 0 1px rgba(14, 27, 44, 0.08);
    background: #f5f7fa;
    font-size: 12.5px;
    color: #33465e;
  }
  .titlebar {
    display: flex;
    align-items: center;
    height: 40px;
    padding: 0 14px;
    background: #eceff4;
    border-bottom: 1px solid #dde3ec;
  }
  .lights { display: flex; gap: 7px; }
  .lights i { width: 11px; height: 11px; border-radius: 50%; }
  .lights .r { background: #ff5f57; }
  .lights .y { background: #febc2e; }
  .lights .g { background: #28c840; }
  .title { flex: 1; text-align: center; font-size: 12.5px; font-weight: 600; color: #51637c; }
  .spacer { width: 57px; }
  .win { display: flex; height: 360px; }
  .sidebar { width: 170px; background: #eceff4; border-right: 1px solid #dde3ec; padding: 10px 8px; }
  .side-item { font-size: 12.5px; color: #33465e; padding: 6px 9px; border-radius: 6px; }
  .side-item.on { background: #2a6fdb; color: #fff; font-weight: 600; }
  .main { flex: 1; background: #fff; display: flex; flex-direction: column; min-width: 0; }
  .toolbar { display: flex; gap: 8px; align-items: center; padding: 10px 14px; border-bottom: 1px solid #eff2f7; }
  .search {
    flex: 1;
    max-width: 200px;
    height: 24px;
    border-radius: 6px;
    background: #f0f3f8;
    border: 1px solid #e2e8f1;
    font-size: 11.5px;
    color: #8a98ac;
    display: flex;
    align-items: center;
    padding: 0 8px;
  }
  .grow { flex: 1; }
  .act {
    height: 24px;
    border-radius: 6px;
    background: #2a6fdb;
    color: #fff;
    font-size: 11.5px;
    font-weight: 600;
    display: flex;
    align-items: center;
    padding: 0 10px;
  }
  table { border-collapse: collapse; width: 100%; }
  th {
    text-align: left;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #8a98ac;
    padding: 8px 14px;
    border-bottom: 1px solid #eff2f7;
    font-weight: 600;
  }
  td { padding: 9px 14px; border-bottom: 1px solid #f4f6fa; }
  .mono, .logline { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 11.5px; }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    border-radius: 999px;
    padding: 2px 9px;
  }
  .pill i { width: 6px; height: 6px; border-radius: 50%; }
  .pill.run { background: #e7f7ee; color: #177a45; }
  .pill.run i { background: #2ecc71; }
  .pill.stop { background: #f0f3f8; color: #8a98ac; }
  .pill.stop i { background: #b5c0cf; }
  .logs { margin-top: auto; background: #0e1b2c; padding: 10px 14px; }
  .logline { color: #9db2ce; line-height: 1.75; }
  .logline b { color: #8fb6f0; font-weight: 600; }
  @media (max-width: 640px) {
    .sidebar { display: none; }
    .win { height: 300px; }
  }
</style>
